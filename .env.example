# Copy this file to .env for local runs.
# Never put private API keys or machine-specific secrets in tracked files.

# TouchDesigner / StreamDiffusionTD OSC bridge.
OSC_IP=127.0.0.1
OSC_PORT=7001
OSC_PROMPT_ADDRESS=/prompt
OSC_PARTIAL_TEXT_ADDRESS=/partial_text
OSC_GESTURE_ADDRESS=/gesture

# Camera input.
CAMERA_INDEX=0
MIRROR_CAMERA=true
SHOW_PREVIEW=true

# Recognizer backend.
# rule_based is a starter ASL fingerspelling recognizer using MediaPipe hand landmarks.
# temporal_model loads SIGN_MODEL_PATH after you collect clips and train a model.
SIGN_RECOGNITION_BACKEND=rule_based
SIGN_MODEL_PATH=models/temporal_sign_model.pkl
SIGN_MIN_CONFIDENCE=0.64

# auto commits a sign after it is held steady.
# manual lets you press Space to append the currently detected sign.
SIGN_COMMIT_MODE=auto
SIGN_HOLD_SECONDS=0.75
SIGN_RELEASE_SECONDS=0.25
SIGN_REPEAT_COOLDOWN_SECONDS=1.8
AUTO_SEND_PROMPT=true
MAX_TEXT_CHARS=160

# Prompt identity controls, matching the voice-to-visual project.
DEFAULT_GENDER=neutral
DEFAULT_AGE=adult
DEFAULT_VISUAL_MODE=asian_american
